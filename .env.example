# ─── Groq ──────────────────────────────────────────────────────────────────
# Get your key from: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Supabase PostgreSQL ───────────────────────────────────────────────────
# From Supabase Dashboard → Settings → Database → Connection String (URI)
# Replace [PASSWORD] and [PROJECT_REF] with your actual values
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ─── App Settings ─────────────────────────────────────────────────────────
APP_NAME=Sales Assistant Agent
APP_VERSION=1.0.0
DEBUG=false

# ─── Memory Settings ──────────────────────────────────────────────────────
MEMORY_CONTEXT_LIMIT=20
EVAL_CONFIDENCE_THRESHOLD=0.70
